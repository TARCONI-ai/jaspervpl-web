---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { ui } from '../i18n';
const t = ui.es;
const posts = (await getCollection('blog', (p) => p.data.lang === 'es' && !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = posts.slice(0, 6);
---
<Base title="Inicio" lang="es" permalink="/" altPermalink="/nl/"
      description="SEO, inteligencia artificial y marketing digital. Artículos, recursos y servicios de Jasper van Puffelen López.">
  <div class="wrap">
    <section class="hero">
      <span class="eyebrow">SEO · IA · Marketing digital</span>
      <h1>Posicionamiento para buscadores y para modelos de IA</h1>
      <p>Soy Jasper van Puffelen López. Escribo sobre SEO, AIO/GEO e inteligencia artificial aplicada al marketing, y ayudo a negocios a ser encontrados — por personas y por máquinas.</p>
    </section>
    <h2 class="section-label">{t.latest}</h2>
    <div class="post-grid">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</Base>
