---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import PostCard from '../../../components/PostCard.astro';
import CategoryFilter from '../../../components/CategoryFilter.astro';
const posts = (await getCollection('blog', (p) => p.data.lang === 'nl' && !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const categories = [...new Set(posts.flatMap((p) => p.data.categories))];
---
<Base title="Blog" lang="nl" permalink="/nl/blog-2/" altPermalink="/blog/"
      description="Artikelen over SEO, kunstmatige intelligentie en digitale marketing.">
  <div class="wrap">
    <h1 class="page-title">Blog</h1>
    <CategoryFilter lang="nl" categories={categories} />
    <div class="post-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</Base>
