---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import HeroBauhaus from '../../components/HeroBauhaus.astro';
import { ui, url } from '../../i18n';
const t = ui.nl;
const posts = (await getCollection('blog', (p) => p.data.lang === 'nl' && !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = posts.slice(0, 6);
---
<Base title="Home" lang="nl" permalink="/nl/" altPermalink="/"
      description="SEO, kunstmatige intelligentie en digitale marketing. Artikelen, middelen en diensten van Jasper van Puffelen López.">
  <HeroBauhaus
    introLine1="Hoi, ik ben Jasper van Puffelen López,"
    introLine2="consultant SEO en kunstmatige intelligentie"
    typeText="Leuk dat je langskomt. Ik maak merken vindbaar voor zoekmachines én AI-modellen. Wat gaan we bouwen?"
    pills={[
      { href: url('/nl/contact/'), label: 'Vertel me je project' },
      { href: url('/nl/diensten/'), label: 'Bekijk diensten' },
      { href: url('/nl/blog-2/'), label: 'Lees de blog' },
      { href: url('/nl/middelen/'), label: 'Ontdek middelen' },
    ]}
    emailLabel="Mail me"
    email="jaspervpl@gmail.com"
  />
  <div class="after-hero">
    <div class="wrap">
      <h2 class="section-label">{t.latest}</h2>
      <div class="post-grid">
        {latest.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </div>
</Base>
