---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { ui } from '../../i18n';
const t = ui.nl;
const posts = (await getCollection('blog', (p) => p.data.lang === 'nl' && !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = posts.slice(0, 6);
---
<Base title="Home" lang="nl" permalink="/nl/" altPermalink="/"
      description="SEO, kunstmatige intelligentie en digitale marketing. Artikelen, middelen en diensten van Jasper van Puffelen López.">
  <div class="wrap">
    <section class="hero">
      <span class="eyebrow">SEO · AI · Digitale marketing</span>
      <h1>Vindbaarheid voor zoekmachines én AI-modellen</h1>
      <p>Ik ben Jasper van Puffelen López. Ik schrijf over SEO, AIO/GEO en kunstmatige intelligentie in marketing, en help bedrijven gevonden te worden — door mensen en door machines.</p>
    </section>
    <h2 class="section-label">{t.latest}</h2>
    <div class="post-grid">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</Base>
