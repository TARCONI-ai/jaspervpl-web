---
import { ui } from '../i18n';
interface Props { lang: 'es' | 'nl' }
const { lang } = Astro.props;
const t = ui[lang];
const legal = lang === 'es'
  ? [['/aviso-legal/', t.footerLegal], ['/politica-de-privacidad/', t.footerPrivacy], ['/politica-de-cookies/', t.footerCookies]]
  : [['/nl/juridische-kennisgeving/', t.footerLegal], ['/nl/privacybeleid/', t.footerPrivacy], ['/nl/cookiebeleid/', t.footerCookies]];
---
<footer class="site-footer">
  <div class="wrap">
    <span>© {new Date().getFullYear()} Jasper van Puffelen López · {t.tagline}</span>
    <nav aria-label="legal">
      {legal.map(([href, label]) => <a href={href}>{label}</a>)}
    </nav>
  </div>
</footer>
