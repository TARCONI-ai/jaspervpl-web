---
import { ui, url } from '../i18n';
interface Props { lang: 'es' | 'nl' }
const { lang } = Astro.props;
const t = ui[lang];
const legal = lang === 'es'
  ? [[url('/aviso-legal/'), t.footerLegal], [url('/politica-de-privacidad/'), t.footerPrivacy], [url('/politica-de-cookies/'), t.footerCookies]]
  : [[url('/nl/juridische-kennisgeving/'), t.footerLegal], [url('/nl/privacybeleid/'), t.footerPrivacy], [url('/nl/cookiebeleid/'), t.footerCookies]];
---
<footer class="site-footer">
  <div class="wrap">
    <span>© {new Date().getFullYear()} Jasper van Puffelen López · {t.tagline}</span>
    <nav aria-label="legal">
      {legal.map(([href, label]) => <a href={href}>{label}</a>)}
    </nav>
  </div>
</footer>
