---
import { nav, url } from '../i18n';
interface Props { lang: 'es' | 'nl'; altPermalink?: string }
const { lang, altPermalink } = Astro.props;
const items = nav[lang];
const current = Astro.url.pathname;
const switchHref = url(altPermalink ?? (lang === 'es' ? '/nl/' : '/'));
const switchLabel = lang === 'es' ? 'NL' : 'ES';
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href={url(lang === 'es' ? '/' : '/nl/')}><img src={`${import.meta.env.BASE_URL}/logo.png`} alt="JasperVPL" /></a>
    <nav class="site-nav" aria-label="principal">
      {items.map((i) => <a href={i.href} aria-current={current === i.href ? 'page' : undefined}>{i.label}</a>)}
    </nav>
    <a class="lang-switch" href={switchHref} aria-label={lang === 'es' ? 'Nederlandse versie' : 'Versión en español'}>{switchLabel}</a>
  </div>
</header>
