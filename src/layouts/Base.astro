---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang: 'es' | 'nl';
  permalink: string;           // ruta relativa con barra final, p. ej. /blog/noticias/google-ai-mode/
  altPermalink?: string;       // ruta de la traducción en el otro idioma, si existe
  ogImage?: string;
  jsonLd?: object;
}

const { title, description, lang, permalink, altPermalink, ogImage, jsonLd } = Astro.props;
const site = 'https://www.jaspervpl.com';
const canonical = site + permalink;
const altLang = lang === 'es' ? 'nl' : 'es';
const siteTitle = lang === 'es'
  ? 'Jasper van Puffelen López — SEO e IA'
  : 'Jasper van Puffelen López — SEO en AI';
const fullTitle = permalink === '/' || permalink === '/nl/' ? siteTitle : `${title} | jaspervpl.com`;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang={lang} href={canonical} />
  {altPermalink && <link rel="alternate" hreflang={altLang} href={site + altPermalink} />}
  {altPermalink && <link rel="alternate" hreflang="x-default" href={lang === 'es' ? canonical : site + altPermalink} />}
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="jaspervpl.com" href="/rss.xml" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'nl_NL'} />
  {ogImage && <meta property="og:image" content={site + ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;900&display=swap" />
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
</head>
<body>
  <Header lang={lang} altPermalink={altPermalink} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
